{
    "type": "AdaptiveCard",
    "version": "1.6",
    "body": [
        {
            "type": "ColumnSet",
            "columns": [
                {
                    "type": "Column",
					"items": [
						{
							"type": "Image",
							"style": "Person",
							"url": "/img/check.png",
							"size": "Small"
						}
					],
					"width": "auto"
                },
                {
					"type": "Column",
					"items": [
						{
							"type": "TextBlock",
							"weight": "Bolder",
							"text": "${title}",
							"wrap": true
						}
					],
					"width": "stretch"
				}


            ]
        }
    ],
    "actions": [
        {
            "type": "Action.OpenUrl",
            "title": "Click me"      
        }
    ]
}